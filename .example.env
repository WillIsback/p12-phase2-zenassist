# ============================================
# Inference Configuration
# ============================================

# Mode d'inférence : "LOCAL" ou "PREMIUM" pour vLLM auto-hébergé, toute autre valeur pour Mistral API
INFERENCE_MODE=LOCAL

# --- Mode LOCAL (vLLM) ---
# URL de base de votre serveur vLLM (ex: http://192.168.1.100:8000/v1)
LLM_BASE_URL=http://localhost:8000/v1
# Clé API du provider local (laisser vide ou "none" si vLLM sans authentification)
PROVIDER_API_KEY=none

# --- Mode Mistral (payant) ---
# Clé API Mistral (https://console.mistral.ai/)
MISTRAL_API_KEY=your-mistral-api-key-here

# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=5555
DB_NAME=dev_ia_p12
DB_USER=postgres
DB_PASSWORD=postgres